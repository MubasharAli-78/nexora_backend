/// Fraud / risk detection.

model FraudRule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  storeId     String?  @map("store_id") @db.Uuid
  name        String
  description String?
  ruleType    String   @map("rule_type") // velocity/amount/geo/blocklist/custom
  configJson  Json     @default("{}") @map("config_json")
  severity    String   @default("medium") // low/medium/high/critical
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, isActive])
  @@map("fraud_rules")
  @@schema("app")
}

model FraudAlert {
  id           String    @id @default(uuid()) @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  storeId      String?   @map("store_id") @db.Uuid
  orderId      String?   @map("order_id") @db.Uuid
  ruleId       String?   @map("rule_id") @db.Uuid
  riskScore    Decimal   @default(0) @map("risk_score") @db.Decimal(8, 4)
  severity     String    @default("medium")
  status       String    @default("open") // open/reviewing/confirmed/dismissed
  reason       String?
  detailsJson  Json      @default("{}") @map("details_json")
  resolvedAt   DateTime? @map("resolved_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([tenantId, status, createdAt(sort: Desc)])
  @@index([tenantId, storeId, severity])
  @@map("fraud_alerts")
  @@schema("app")
}

model RiskEvent {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  storeId     String?  @map("store_id") @db.Uuid
  eventType   String   @map("event_type") // login/checkout/refund/chargeback
  entityType  String?  @map("entity_type") // order/customer
  entityId    String?  @map("entity_id") @db.Uuid
  riskScore   Decimal  @default(0) @map("risk_score") @db.Decimal(8, 4)
  signalsJson Json     @default("{}") @map("signals_json")
  occurredAt  DateTime @default(now()) @map("occurred_at") @db.Timestamptz

  @@index([tenantId, occurredAt(sort: Desc)])
  @@map("risk_events")
  @@schema("app")
}
