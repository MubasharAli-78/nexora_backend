/// Global identity tables. NOT tenant-scoped — access is mediated by backend guards.

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String
  emailNormalized String    @unique @map("email_normalized")
  fullName        String?   @map("full_name")
  avatarFileId    String?   @map("avatar_file_id") @db.Uuid
  status          String    @default("active") // active/invited/suspended/deleted
  emailVerifiedAt DateTime? @map("email_verified_at") @db.Timestamptz
  lastLoginAt     DateTime? @map("last_login_at") @db.Timestamptz
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  credential  UserCredential?
  sessions    UserSession[]
  memberships TenantMembership[]

  @@index([status])
  @@index([lastLoginAt(sort: Desc)])
  @@map("users")
  @@schema("app")
}

/// Pending email-OTP signups. A row lives here only until the OTP is verified;
/// on success the user/tenant are materialized and the row is deleted. NOT tenant-scoped.
model SignupVerification {
  id              String   @id @default(uuid()) @db.Uuid
  emailNormalized String   @unique @map("email_normalized")
  email           String
  fullName        String   @map("full_name")
  companyName     String   @map("company_name")
  tenantSlug      String?  @map("tenant_slug")
  passwordHash    String   @map("password_hash")
  otpHash         String   @map("otp_hash")
  attempts        Int      @default(0)
  resendCount     Int      @default(0) @map("resend_count")
  expiresAt       DateTime @map("expires_at") @db.Timestamptz
  lastSentAt      DateTime @default(now()) @map("last_sent_at") @db.Timestamptz
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([expiresAt])
  @@map("signup_verifications")
  @@schema("app")
}

model UserCredential {
  id                 String    @id @default(uuid()) @db.Uuid
  userId             String    @unique @map("user_id") @db.Uuid
  passwordHash       String    @map("password_hash")
  passwordUpdatedAt  DateTime  @default(now()) @map("password_updated_at") @db.Timestamptz
  failedLoginCount   Int       @default(0) @map("failed_login_count")
  lockedUntil        DateTime? @map("locked_until") @db.Timestamptz
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([lockedUntil])
  @@map("user_credentials")
  @@schema("app")
}

model UserSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @map("user_id") @db.Uuid
  currentTenantId String?   @map("current_tenant_id") @db.Uuid
  status          String    @default("active") // active/revoked/expired
  ipAddress       String?   @map("ip_address") @db.Inet
  userAgentHash   String?   @map("user_agent_hash")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  lastSeenAt      DateTime  @default(now()) @map("last_seen_at") @db.Timestamptz
  expiresAt       DateTime  @map("expires_at") @db.Timestamptz
  revokedAt       DateTime? @map("revoked_at") @db.Timestamptz

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId, status])
  @@index([currentTenantId])
  @@index([expiresAt])
  @@index([lastSeenAt(sort: Desc)])
  @@map("user_sessions")
  @@schema("app")
}

model RefreshToken {
  id                String    @id @default(uuid()) @db.Uuid
  sessionId         String    @map("session_id") @db.Uuid
  tokenHash         String    @unique @map("token_hash")
  familyId          String    @map("family_id") @db.Uuid
  replacedByTokenId String?   @map("replaced_by_token_id") @db.Uuid
  expiresAt         DateTime  @map("expires_at") @db.Timestamptz
  revokedAt         DateTime? @map("revoked_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  session UserSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([familyId])
  @@index([expiresAt])
  @@map("refresh_tokens")
  @@schema("app")
}
