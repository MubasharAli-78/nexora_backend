# ==============================================
# Nexora Backend Environment
# ==============================================
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
# Comma-separated list of allowed frontend origins (Next.js app)
CORS_ORIGINS=http://localhost:3000

# ==============================================
# Database (Supabase PostgreSQL)
# ⚠️  REPLACE your-db-password with your real Supabase DB password
#     (Supabase Dashboard → Project Settings → Database → Database password)
# DATABASE_URL  -> transaction pooler (6543), used by the running app
# DIRECT_URL    -> session pooler   (5432), used by prisma migrate
# ==============================================
DATABASE_URL="postgresql://postgres.vpvgrobmohhkyzebmzyu:your-db-password@aws-1-ap-southeast-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.vpvgrobmohhkyzebmzyu:your-db-password@aws-1-ap-southeast-2.pooler.supabase.com:5432/postgres"

# ==============================================
# JWT / Auth secrets  (CHANGE THESE in production — generate with: openssl rand -base64 48)
# ==============================================
JWT_ACCESS_SECRET=replace-with-openssl-rand-base64-48
JWT_ACCESS_TTL=900
JWT_ISSUER=nexora
JWT_AUDIENCE=nexora-app
REFRESH_TOKEN_TTL_DAYS=30
SESSION_TTL_DAYS=30
# 32-byte key (base64 or hex) for field-level encryption of PII / integration secrets
FIELD_ENCRYPTION_KEY=ZGV2X2ZpZWxkX2VuY3J5cHRpb25fa2V5XzMyYnl0ZXNfMDE=
# Cookie domain (leave blank for localhost)
COOKIE_DOMAIN=
COOKIE_SECURE=false

# ==============================================
# Auth SMTP Configuration (OTP & Password Reset / Invitations)
# Uses Hostinger Titan for tenant-facing auth emails
# ==============================================
SMTP_HOST=smtp.titan.email
SMTP_PORT=465
SMTP_USERNAME=hello@visiontact.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=hello@visiontact.com
SMTP_FROM_NAME=Nexora
SMTP_USE_TLS=false
SMTP_USE_SSL=true

# ==============================================
# Frontend URLs (used in invitation / reset email links)
# ==============================================
APP_PUBLIC_URL=http://localhost:3000
INVITE_ACCEPT_PATH=/invite/accept
PASSWORD_RESET_PATH=/reset-password

# ==============================================
# Redis (BullMQ workers). Optional in dev — workers disabled if blank.
# ==============================================
REDIS_URL=

# ==============================================
# Supabase Storage (S3-compatible). Fill from Supabase → Storage → S3 connection.
# Optional — file endpoints return 503 until configured.
# ==============================================
SUPABASE_S3_ENDPOINT=https://vpvgrobmohhkyzebmzyu.storage.supabase.co/storage/v1/s3
SUPABASE_S3_REGION=ap-southeast-2
SUPABASE_S3_ACCESS_KEY_ID=
SUPABASE_S3_SECRET_ACCESS_KEY=
STORAGE_BUCKET_PRIVATE=nexora-private
STORAGE_BUCKET_PRODUCT=nexora-product-assets
STORAGE_BUCKET_PUBLIC=nexora-public
