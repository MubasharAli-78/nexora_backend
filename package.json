{
  "name": "nexora-backend",
  "version": "0.1.0",
  "description": "Nexora SaaS multi-tenant backend (NestJS + Prisma + Supabase Postgres)",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "worker:dev": "ts-node --transpile-only src/worker/main.ts",
    "worker:prod": "node dist/worker/main.js",
    "lint": "eslint \"src/**/*.ts\" --fix",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:migrate:dev": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio",
    "db:seed": "ts-node --transpile-only --project prisma/seed/tsconfig.json prisma/seed/seed.ts",
    "db:setup": "prisma migrate deploy && npm run db:seed",
    "sync:shopify": "ts-node -T src/bootstrap-shopify.ts"
  },
  "prisma": {
    "schema": "prisma/schema",
    "seed": "ts-node --transpile-only --project prisma/seed/tsconfig.json prisma/seed/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@aws-sdk/s3-request-presigner": "^3.700.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/config": "^4.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.3.0",
    "argon2": "^0.41.1",
    "bullmq": "^5.34.0",
    "cookie-parser": "^1.4.7",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "nestjs-pino": "^4.3.0",
    "nodemailer": "^6.10.0",
    "pino-http": "^10.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "eslint": "^9.17.0",
    "jest": "^30.4.2",
    "prisma": "^6.3.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
